<form class="vitruvium {{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{item.img}}" title="{{item.name}}" data-edit="img"/>
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Название способности"/>
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Описание</a>
    <a class="item" data-tab="details">Параметры</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>

    <div class="tab" data-group="primary" data-tab="details">
      <div class="form-group">
        <label>Уровень</label>
        <div class="form-fields">
          <input type="number" name="system.level.value" value="{{system.level.value}}" min="1" max="6"/>
        </div>
      </div>

      <div class="form-group">
        <label>Тип способности</label>
        <div class="form-fields">
          <select name="system.abilityType.value">
            {{#select system.abilityType.value}}
            <option value="знание">Знание</option>
            <option value="навык">Навык</option>
            <option value="черта">Черта</option>
            <option value="источник">Источник</option>
            <option value="мастерство">Мастерство</option>
            <option value="приём">Приём</option>
            {{/select}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Домен</label>
        <div class="form-fields">
          <input type="text" name="system.domain.value" value="{{system.domain.value}}" placeholder="Название домена"/>
        </div>
      </div>

      <div class="form-group">
        <label>Активация</label>
        <div class="form-fields">
          <select name="system.activation.value">
            {{#select system.activation.value}}
            <option value="пассивная">Пассивная</option>
            <option value="активная">Активная</option>
            {{/select}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Стоимость (вдохновение)</label>
        <div class="form-fields">
          <input type="number" name="system.cost.value" value="{{system.cost.value}}" min="0"/>
        </div>
      </div>

      <div class="form-group">
        <label>Эффект</label>
        <div class="form-fields">
          <textarea name="system.effect.value" rows="3">{{system.effect.value}}</textarea>
        </div>
      </div>
    </div>
  </section>
</form>
