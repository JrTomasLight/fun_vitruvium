<div class="items-list">
  <!-- Оружие -->
  <div class="items-header flexrow">
    <span class="item-name">Оружие</span>
    <span class="item-detail">Тип</span>
    <span class="item-detail">Урон</span>
    <span class="item-controls">
      <a class="item-control item-create" title="Создать оружие" data-type="weapon">
        <i class="fas fa-plus"></i>
      </a>
    </span>
  </div>
  
  {{#each weapons as |weapon|}}
  <div class="item flexrow" data-item-id="{{weapon._id}}">
    <div class="item-name">
      <div class="item-image">
        <img src="{{weapon.img}}" title="{{weapon.name}}" width="24" height="24"/>
      </div>
      <span>{{weapon.name}}</span>
    </div>
    <div class="item-detail">{{weapon.system.attackType.value}}</div>
    <div class="item-detail">{{weapon.system.damage.value}}</div>
    <div class="item-controls">
      <a class="item-control item-edit" title="Редактировать"><i class="fas fa-edit"></i></a>
      <a class="item-control item-delete" title="Удалить"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}

  <!-- Броня -->
  <div class="items-header flexrow">
    <span class="item-name">Броня</span>
    <span class="item-detail">Блок</span>
    <span class="item-detail">Прочность</span>
    <span class="item-controls">
      <a class="item-control item-create" title="Создать броню" data-type="armor">
        <i class="fas fa-plus"></i>
      </a>
    </span>
  </div>
  
  {{#each armors as |armor|}}
  <div class="item flexrow" data-item-id="{{armor._id}}">
    <div class="item-name">
      <div class="item-image">
        <img src="{{armor.img}}" title="{{armor.name}}" width="24" height="24"/>
      </div>
      <span>{{armor.name}}</span>
    </div>
    <div class="item-detail">{{armor.system.block.value}}</div>
    <div class="item-detail">{{armor.system.durability.value}}/{{armor.system.durabilityMax.value}}</div>
    <div class="item-controls">
      <a class="item-control item-edit" title="Редактировать"><i class="fas fa-edit"></i></a>
      <a class="item-control item-delete" title="Удалить"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}

  <!-- Особенности -->
  <div class="items-header flexrow">
    <span class="item-name">Особенности</span>
    <span class="item-detail">Тип</span>
    <span class="item-controls">
      <a class="item-control item-create" title="Создать особенность" data-type="feature">
        <i class="fas fa-plus"></i>
      </a>
    </span>
  </div>
  
  {{#each features as |feature|}}
  <div class="item flexrow" data-item-id="{{feature._id}}">
    <div class="item-name">
      <div class="item-image">
        <img src="{{feature.img}}" title="{{feature.name}}" width="24" height="24"/>
      </div>
      <span>{{feature.name}}</span>
    </div>
    <div class="item-detail">{{feature.system.featureType.value}}</div>
    <div class="item-controls">
      <a class="item-control item-edit" title="Редактировать"><i class="fas fa-edit"></i></a>
      <a class="item-control item-delete" title="Удалить"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}
</div>
