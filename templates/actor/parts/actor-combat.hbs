<div class="combat-panel">
  <div class="combat-stats grid grid-2col">
    <div class="stat-group">
      <h3>Ближний бой</h3>
      <div class="stat-row flexrow">
        <span>Атака (Движение):</span>
        <button type="button" class="roll-attribute" data-attr="movement" data-difficulty="0">
          <i class="fas fa-dice"></i> Бросить
        </button>
      </div>
    </div>
    
    <div class="stat-group">
      <h3>Дальний бой</h3>
      <div class="stat-row flexrow">
        <span>Атака (Внимание):</span>
        <button type="button" class="roll-attribute" data-attr="perception" data-difficulty="0">
          <i class="fas fa-dice"></i> Бросить
        </button>
      </div>
    </div>
  </div>
  
  <div class="combat-actions">
    <h3>Действия в бою</h3>
    <div class="actions-list">
      <div class="action-item flexrow">
        <span class="action-name">Простая атака</span>
        <span class="action-cost">1 ОД</span>
        <span class="action-desc">Нанести урон, оттолкнуть, притянуть</span>
      </div>
      <div class="action-item flexrow">
        <span class="action-name">Простой манёвр</span>
        <span class="action-cost">1 ОД</span>
        <span class="action-desc">Преодолеть расстояние, лечь, встать, прыжок</span>
      </div>
      <div class="action-item flexrow">
        <span class="action-name">Простое взаимодействие</span>
        <span class="action-cost">1 ОД</span>
        <span class="action-desc">Использовать/поднять/бросить предмет</span>
      </div>
      <div class="action-item flexrow">
        <span class="action-name">Сложная атака</span>
        <span class="action-cost">2 ОД</span>
        <span class="action-desc">Сбить с ног, захватить, обезоружить</span>
      </div>
      <div class="action-item flexrow">
        <span class="action-name">Сложный манёвр</span>
        <span class="action-cost">2 ОД</span>
        <span class="action-desc">Преодолеть расстояние без провокации</span>
      </div>
    </div>
  </div>
</div>
