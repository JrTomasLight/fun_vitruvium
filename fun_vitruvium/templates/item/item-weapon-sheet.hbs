<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{item.img}}" title="{{item.name}}" data-edit="img"/>
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Название оружия"/>
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Описание</a>
    <a class="item" data-tab="details">Параметры</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>

    <div class="tab" data-group="primary" data-tab="details">
      <div class="form-group">
        <label>Тип атаки</label>
        <div class="form-fields">
          <select name="system.attackType.value">
            {{#select system.attackType.value}}
            <option value="ближний">Ближний бой</option>
            <option value="дальний">Дальний бой</option>
            {{/select}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Характеристика</label>
        <div class="form-fields">
          <select name="system.attribute.value">
            {{#select system.attribute.value}}
            <option value="body">Телосложение</option>
            <option value="perception">Внимание</option>
            <option value="movement">Движение</option>
            <option value="mind">Мышление</option>
            <option value="influence">Влияние</option>
            <option value="will">Воля</option>
            {{/select}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Урон</label>
        <div class="form-fields">
          <input type="number" name="system.damage.value" value="{{system.damage.value}}" min="0"/>
        </div>
      </div>

      <div class="form-group">
        <label>Свойства</label>
        <div class="form-fields">
          <input type="text" name="system.properties.value" value="{{system.properties.value}}" placeholder="Особые свойства"/>
        </div>
      </div>
    </div>
  </section>
</form>
