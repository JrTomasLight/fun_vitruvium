<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{item.img}}" title="{{item.name}}" data-edit="img"/>
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Название брони"/>
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Описание</a>
    <a class="item" data-tab="details">Параметры</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>

    <div class="tab" data-group="primary" data-tab="details">
      <div class="form-group">
        <label>Блок (поглощение урона)</label>
        <div class="form-fields">
          <input type="number" name="system.block.value" value="{{system.block.value}}" min="0"/>
        </div>
      </div>

      <div class="form-group">
        <label>Текущая прочность</label>
        <div class="form-fields">
          <input type="number" name="system.durability.value" value="{{system.durability.value}}" min="0" max="{{system.durabilityMax.value}}"/>
        </div>
      </div>

      <div class="form-group">
        <label>Макс. прочность</label>
        <div class="form-fields">
          <input type="number" name="system.durabilityMax.value" value="{{system.durabilityMax.value}}" min="0"/>
        </div>
      </div>

      <div class="form-group">
        <label>Мин. Телосложение</label>
        <div class="form-fields">
          <input type="number" name="system.minBody.value" value="{{system.minBody.value}}" min="0" max="6"/>
        </div>
      </div>

      <div class="form-group">
        <label>Штраф к скорости</label>
        <div class="form-fields">
          <input type="number" name="system.speedPenalty.value" value="{{system.speedPenalty.value}}" min="0"/>
        </div>
      </div>
    </div>
  </section>
</form>
